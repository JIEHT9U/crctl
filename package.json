{
  "name": "crctl",
  "version": "0.5.0",
  "description": "CLI utility for managing Claude Code remote-control sessions via tmux",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "crctl": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "echo 'crctl built — see dist/'"
  },
  "keywords": [
    "claude",
    "claude-code",
    "remote-control",
    "tmux",
    "cli",
    "session-manager",
    "terminal",
    "devtools"
  ],
  "author": "JIEHT9U",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JIEHT9U/crctl.git"
  },
  "bugs": {
    "url": "https://github.com/JIEHT9U/crctl/issues"
  },
  "homepage": "https://github.com/JIEHT9U/crctl#readme",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^25.9.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "release-it": "^20.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "release-it": {
    "github": {
      "release": true,
      "tokenRef": "GITHUB_RELESE_TOKEN"
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits",
        "infile": "CHANGELOG.md"
      }
    },
    "hooks": {
      "after:bump": "npm run build && git add -A"
    }
  }
}
